NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-only. Never prefix with NEXT_PUBLIC_ - this key bypasses Row Level
# Security and is required to invite staff members (auth.admin.inviteUserByEmail).
# Find it in Supabase Dashboard -> Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Base URL used to build the staff invite accept-invite redirect link.
# Must also be added to Supabase Dashboard -> Authentication -> URL Configuration
# -> Redirect URLs (e.g. https://yourapp.com/auth/accept-invite).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Password for the shared "Try the demo" account (demo@trak.app), used by
# the "Try the demo" button on the login page. It's created automatically
# (with two staff members and sample clients) the first time anyone signs
# in this way. Optional - falls back to a hardcoded default if unset.
DEMO_USER_PASSWORD=choose_a_demo_password

# Only needed for local Supabase dev (`supabase start`) to send real auth
# emails (invites, signup confirmations, password resets) through Resend
# instead of the heavily-rate-limited default. On the hosted project,
# configure the same Resend SMTP credentials in the Dashboard instead:
# Authentication -> Emails -> SMTP Settings.
RESEND_API_KEY=your_resend_api_key
RESEND_SENDER_EMAIL=no-reply@yourdomain.com
